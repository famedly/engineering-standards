# Server
LISTEN_ADDR=0.0.0.0:3000
BASE_URL=http://localhost:3000

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://standards:standards@localhost:5432/engineering_standards

# GitHub App – create a test app at https://github.com/settings/apps
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=./github-app-key.pem
# or inline: GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Anthropic Claude API (for AI reviews)
ANTHROPIC_API_KEY=sk-ant-...

# OIDC (e.g. Zitadel, Keycloak, Auth0)
OIDC_ISSUER_URL=https://your-idp.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URL=http://localhost:3000/auth/callback

# Extra OAuth2 scopes requested at login (comma-separated).
# Some IdPs require specific scopes to include role/group claims in tokens.
# Zitadel: include project roles in the access token
# OIDC_EXTRA_SCOPES=urn:zitadel:iam:org:projects:roles

# RBAC: map an ID token claim to roles (admin / viewer).
# When OIDC_ROLE_CLAIM is unset, all authenticated users are admins (backwards
# compatible).  Once set, users whose claim value matches neither admin nor
# viewer values are denied access entirely.
# Supports dot-notation for nested claims (e.g. urn:zitadel:iam:org:projects:roles).
# Roles are re-evaluated via the OIDC UserInfo endpoint every 5 minutes.
# OIDC_ROLE_CLAIM=urn:zitadel:iam:org:projects:roles
# OIDC_ADMIN_VALUES=admin,engineering-lead
# OIDC_VIEWER_VALUES=developer,readonly

# Standards source repository
STANDARDS_REPO_OWNER=your-org
STANDARDS_REPO_NAME=engineering-standards

# Tracing / Logging
RUST_LOG=engineering_standards_app=debug,tower_http=debug
